{
  "name": "l2d-widget",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "",
  "author": "hacxy",
  "license": "MIT",
  "keywords": [
    "l2d",
    "Live2D",
    "cubism2",
    "cubism6",
    "Live2D for Web"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "vite build --watch --sourcemap",
    "demo": "vite --config vite.demo.config.ts",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --fix",
    "prepare": "simple-git-hooks",
    "commit": "git-cz",
    "release": "bump"
  },
  "devDependencies": {
    "@hacxy/bump": "^0.3.2",
    "@hacxy/eslint-config": "^0.5.5",
    "@hacxy/fe": "^0.6.1",
    "@hacxy/tsconfig": "^0.1.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.11.0",
    "eslint": "^10.2.0",
    "l2d": "^2.1.1",
    "lint-staged": "^15.4.3",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx fe msg"
  },
  "lint-staged": {
    "*": [
      "npm run lint:staged"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": false
    }
  }
}
