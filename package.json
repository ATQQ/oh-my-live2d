{
  "name": "l2d-widget",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.min.js",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test:site": "vite serve test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --fix",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@hacxy/bump": "^0.3.2",
    "@hacxy/eslint-config": "^0.5.4",
    "@hacxy/fe": "^0.6.1",
    "@hacxy/tsconfig": "^0.1.0",
    "eslint": "^9.39.1",
    "l2d": "^1.0.0",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx fe msg"
  },
  "lint-staged": {
    "*": [
      "npm run lint:staged"
    ]
  }
}
